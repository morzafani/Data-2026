// ========== STATE ==========
let chIdx=0,pgIdx=0,readPages={},showRef=false;
const totalPages=DATA.reduce((s,c)=>s+c.pages.length,0);

// ========== SEARCH ==========
function doSearch(q){
const el=document.getElementById('searchResults');
if(!q||q.length<2){el.classList.remove('show');return}
q=q.toLowerCase();
let results=[];
DATA.forEach((ch,ci)=>{
ch.pages.forEach((pg,pi)=>{
const haystack=(pg.t+' '+pg.search+' '+(pg.html||'')).toLowerCase().replace(/<[^>]*>/g,' ');
if(haystack.includes(q)){
const idx=haystack.indexOf(q);
const snippet=haystack.substring(Math.max(0,idx-40),idx+60).replace(/\s+/g,' ');
results.push({ci,pi,ch:ch.title,t:pg.t,snippet:'...'+snippet+'...'});
}
});
});
// Also search glossary
const glossaryTerms=['referrer url','landing page','utm parameters','gclid','msclkid','fbclid','ad-hop redirect','session context','webview','classification'];
glossaryTerms.forEach(term=>{
if(term.includes(q)){results.unshift({ci:-1,pi:-1,ch:'GLOSSARY',t:term,snippet:'See Signal Glossary at the top of the page'});}
});
if(!results.length){el.classList.remove('show');return}
el.innerHTML=results.slice(0,6).map(r=>`<div class="sr-item" onclick="${r.ci>=0?`goTo(${r.ci},${r.pi})`:'toggleGlossary()'}">
<div class="sr-ch">${r.ch}</div><div class="sr-title">${r.t}</div><div class="sr-match">${r.snippet}</div></div>`).join('');
el.classList.add('show');
}

function goTo(ci,pi){chIdx=ci;pgIdx=pi;showRef=false;render();
document.getElementById('searchInput').value='';
document.getElementById('searchResults').classList.remove('show');}

// ========== GLOSSARY ==========
function toggleGlossary(){
const t=document.getElementById('glossaryToggle'),b=document.getElementById('glossaryBody');
t.classList.toggle('open');b.classList.toggle('show');
}

// ========== RENDER ==========
function render(){
const readCount=Object.keys(readPages).length;
document.getElementById('progressFill').style.width=(readCount/totalPages*100)+'%';
document.getElementById('readCount').textContent=readCount+'/'+totalPages+' read';

// Nav
let nav='';
DATA.forEach((c,i)=>{
const active=!showRef&&i===chIdx?'active':'';
const chRead=c.pages.filter((_,pi)=>readPages[i+'-'+pi]).length;
nav+=`<button class="ch-btn ui ${active}" onclick="chIdx=${i};pgIdx=0;showRef=false;render()">
<div class="icon">${c.icon}</div><div class="label">CH ${c.id}</div><div class="name">${c.title}</div>
<div class="ch-progress"><div class="ch-progress-fill" style="width:${(chRead/c.pages.length)*100}%"></div></div></button>`;
});
nav+=`<button class="ref-btn ui ${showRef?'active':''}" onclick="showRef=true;render()">
<div class="icon">📋</div><div class="label" style="color:var(--orange)">REF</div><div class="name" style="color:${showRef?'var(--orange)':'var(--gray)'}">Quick Ref</div></button>`;
document.getElementById('chNav').innerHTML=nav;

if(showRef){renderQuickRef();return}

const ch=DATA[chIdx],pg=ch.pages[pgIdx],key=chIdx+'-'+pgIdx;
setTimeout(()=>{if(!readPages[key]){readPages[key]=true;render()}},3000);

document.getElementById('chIntro').innerHTML=`<div class="label">CHAPTER ${ch.id} · ${ch.dur}</div><div class="title">${ch.title}</div><div class="desc">${ch.intro}</div>`;
document.getElementById('chIntro').style.display='';

let dots='';
ch.pages.forEach((p,i)=>{
const color=i===pgIdx?'var(--blue)':readPages[chIdx+'-'+i]?'var(--orange)':'var(--border)';
dots+=`<button class="dot ${i===pgIdx?'active':''}" style="background:${color}" onclick="pgIdx=${i};render()"></button>`;
});
document.getElementById('dots').innerHTML=dots;
document.getElementById('dots').style.display='';

let html=`<div class="fade-in"><div class="page-title">${pg.isQ?'<span class="q">Client asks: </span>':''}${pg.t}${pg.badge?'<span class="badge">'+pg.badge+'</span>':''}</div>
<div class="page-meta">Section ${pgIdx+1} of ${ch.pages.length}</div>${pg.html}</div>`;
document.getElementById('pageCard').innerHTML=html;

const isFirst=chIdx===0&&pgIdx===0,isLast=chIdx===DATA.length-1&&pgIdx===ch.pages.length-1;
let navR='';
if(!isFirst)navR+=`<button class="nav-btn nav-prev ui" onclick="goPrev()">← Back</button>`;else navR+='<div></div>';
if(!isLast)navR+=`<button class="nav-btn nav-next ui" onclick="goNext()">Continue →</button>`;
else navR+=`<div class="nav-end ui">🔍 You are the detective. Now go work the case.</div>`;
document.getElementById('navRow').innerHTML=navR;
window.scrollTo({top:0,behavior:'smooth'});
}

function renderQuickRef(){
document.getElementById('chIntro').innerHTML=`<div class="label">QUICK REFERENCE</div><div class="title">Channel Classification Cheat Sheet</div><div class="desc">Pull this up during client calls. Each channel with its key signals and what changed.</div>`;
document.getElementById('dots').innerHTML='';
let html='<div class="fade-in">';
QR_DATA.forEach(r=>{
html+=`<div class="qr-card"><div class="qr-channel">${r.ch}${r.isNew?'<span class="qr-new">NEW</span>':''}</div>
<div class="qr-signals"><strong>Key signals:</strong> ${r.signals}<br><strong>Note:</strong> ${r.note}</div></div>`;
});
html+=`<div class="takeaway" style="margin-top:20px"><div class="t-label">REMEMBER</div>
<div class="t-item">Never make migration claims (traffic moved from A to B)</div>
<div class="t-item">Each site's split may change differently - this is expected</div>
<div class="t-item">Prior analysis retains directional value</div>
<div class="t-item">Offer to look at the client's specific data together</div>
<div class="t-item">Use the Boiman on MMX Agent for data-specific explanations</div>
</div></div>`;
document.getElementById('pageCard').innerHTML=html;
document.getElementById('navRow').innerHTML='';
}

function goNext(){const ch=DATA[chIdx];if(pgIdx<ch.pages.length-1)pgIdx++;else if(chIdx<DATA.length-1){chIdx++;pgIdx=0}render()}
function goPrev(){if(pgIdx>0)pgIdx--;else if(chIdx>0){chIdx--;pgIdx=DATA[chIdx].pages.length-1}render()}

render();
document.addEventListener('click',e=>{if(!e.target.closest('.search-wrap'))document.getElementById('searchResults').classList.remove('show')});
</script>
</body>
</html>
