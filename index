pages:[
{t:'"Why is channel X so different?"',isQ:1,
html:`<div class="client-block"><div class="client-says">CLIENT ASKS:</div><div style="color:var(--white);font-size:15px;margin-bottom:12px">"The numbers for paid search / organic / direct look completely different. What happened?"</div>
